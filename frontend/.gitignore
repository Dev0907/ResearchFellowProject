# ============================================
# Frontend - Next.js .gitignore
# ============================================

# ============================================
# Dependencies
# ============================================
/node_modules
/.pnp
.pnp.js
.pnp.*

# Lock files (optional - uncomment to track)
/package-lock.json
/yarn.lock
/pnpm-lock.yaml

# ============================================
# Environment Variables
# ============================================
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
!.env.local.example

# ============================================
# Next.js Build Outputs
# ============================================
/.next/
/out/
/build
.next/
out/

# ============================================
# Production
# ============================================
/build
/dist

# ============================================
# Testing & Coverage
# ============================================
/coverage
.nyc_output
*.lcov

# ============================================
# Logs
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo
next-env.d.ts
.tsbuildinfo

# ============================================
# IDE & Editors
# ============================================
# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# OS Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini

# Linux
.directory

# ============================================
# Deployment
# ============================================
.vercel
.netlify
.firebase/

# ============================================
# Misc
# ============================================
*.pem
.cache
.parcel-cache
.eslintcache
.stylelintcache

# ============================================
# Turbo
# ============================================
.turbo

# ============================================
# Sentry
# ============================================
.sentryclirc

# ============================================
# Project Specific
# ============================================
# Add frontend-specific ignores here
