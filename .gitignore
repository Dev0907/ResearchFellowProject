# ============================================
# Founder Simulator - Root .gitignore
# ============================================
# This file ensures only source code and documentation
# are tracked, not dependencies or build artifacts
# ============================================

# ============================================
# Dependencies
# ============================================
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ============================================
# Virtual Environments
# ============================================
venv/
env/
ENV/
.venv
.env/
env.bak/
venv.bak/
pythonenv*/

# ============================================
# Environment Variables & Secrets
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
backend/.env
frontend/.env.local
**/.env
**/.env.local

# ============================================
# Build Outputs
# ============================================
# Next.js
.next/
out/
build/

# Python
dist/
*.egg-info/
*.egg

# ============================================
# IDE & Editors
# ============================================
# .vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ============================================
# Operating System
# ============================================
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================
# Logs
# ============================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# Testing & Coverage
# ============================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo
next-env.d.ts

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
*.bak

# ============================================
# Deployment
# ============================================
.vercel
.netlify
